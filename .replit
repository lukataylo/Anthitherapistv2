modules = ["nodejs-20"]

    [agent]
    expertMode = true

    [deployment]
    deploymentTarget = "autoscale"
    build = ["pnpm", "--filter", "@workspace/api-server", "run", "build"]
    run = ["node", "artifacts/api-server/dist/index.cjs"]

    [workflows]
    runButton = "Project"

    [[workflows.workflow]]
    name = "Project"
    mode = "parallel"
    author = "agent"

    [[workflows.workflow.tasks]]
    task = "workflow.run"
    args = "artifacts/mobile: expo"

    [[workflows.workflow.tasks]]
    task = "workflow.run"
    args = "artifacts/api-server: API Server"

    [[workflows.workflow]]
    name = "artifacts/mobile: expo"
    author = "agent"

    [workflows.workflow.metadata]
    outputType = "webview"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "PORT=18115 pnpm --filter @workspace/mobile run dev"

    [[workflows.workflow]]
    name = "artifacts/api-server: API Server"
    author = "agent"

    [workflows.workflow.metadata]
    outputType = "console"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
    waitForPort = 8080

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18115
externalPort = 80

[[ports]]
localPort = 18116
externalPort = 3000

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 180000
    