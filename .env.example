# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables Reference
#
# Copy this file to .env and fill in the values for local development.
# In production (Replit / EAS), set these via the platform's secret management.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Server (required) ────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/antitherapist

# Server port (Replit sets this automatically)
PORT=8080

# JWT signing key for auth tokens. MUST be stable across restarts in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, server generates an ephemeral key (fine for dev, tokens lost on restart).
JWT_SECRET=

# ── API Server (optional) ───────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins. If unset, all origins are allowed.
# ALLOWED_ORIGINS=https://your-app.com,https://staging.your-app.com

# Pino log level: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# ── Mobile App (Expo) ───────────────────────────────────────────────────────

# Domain where the API server is reachable (without protocol).
# The mobile app prepends "https://" to construct the API base URL.
# On Replit, this is auto-set to REPLIT_DEV_DOMAIN.
EXPO_PUBLIC_DOMAIN=localhost:8080

# ── Replit-specific (auto-set by Replit, not needed locally) ─────────────────
# REPLIT_DEV_DOMAIN=
# REPLIT_EXPO_DEV_DOMAIN=
# REPL_ID=

# ── EAS Build (GitHub Actions secret, not in .env) ──────────────────────────
# EXPO_TOKEN — set as a GitHub repository secret, not here
